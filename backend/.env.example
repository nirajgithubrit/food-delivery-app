# Backend environment (copy to .env)
NODE_ENV=development
PORT=3000
MONGODB_URI=mongodb://127.0.0.1:27017/localbite
JWT_SECRET=replace-with-long-random-secret
JWT_REFRESH_SECRET=replace-with-different-long-random-secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
JWT_ACCESS_MAX_AGE_MS=900000
ALLOWED_ORIGINS=http://localhost:4200
COOKIE_SECURE=false
SOCKET_AUTH_OPTIONAL=true
ADMIN_EMAIL=admin@gmail.com
ADMIN_PASSWORD=123456
RESTAURANT_LAT=22.721585
RESTAURANT_LNG=71.647064
RESTAURANT_NAME=Gir Gamthi
RESTAURANT_PHONE=+918155012096
LOG_LEVEL=debug
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Firebase Admin (backend verifies Firebase ID token and issues app JWTs)
# Recommended: Option A only (single-line JSON from downloaded service account file).
# Example shape:
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"...","client_id":"...","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token","auth_provider_x509_cert_url":"https://www.googleapis.com/oauth2/v1/certs","client_x509_cert_url":"...","universe_domain":"googleapis.com"}
FIREBASE_SERVICE_ACCOUNT_JSON=
# Fallback Option B (only if you cannot use FIREBASE_SERVICE_ACCOUNT_JSON)
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# Auth rate limits (optional overrides)
# RATE_LIMIT_AUTH_MAX=120
# RATE_LIMIT_REGISTER_MAX=20
