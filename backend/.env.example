# Backend environment (copy to .env)
NODE_ENV=development
PORT=3000
MONGODB_URI=mongodb://127.0.0.1:27017/localbite
JWT_SECRET=replace-with-long-random-secret
JWT_REFRESH_SECRET=replace-with-different-long-random-secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
JWT_ACCESS_MAX_AGE_MS=900000
ALLOWED_ORIGINS=http://localhost:4200
COOKIE_SECURE=false
SOCKET_AUTH_OPTIONAL=true
ADMIN_EMAIL=admin@gmail.com
ADMIN_PASSWORD=123456
RESTAURANT_LAT=22.721585
RESTAURANT_LNG=71.647064
RESTAURANT_NAME=Gir Gamthi
RESTAURANT_PHONE=+918155012096
LOG_LEVEL=debug
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Firebase Admin (backend verifies Firebase ID token and issues app JWTs)
# Option A: single JSON string from service account key
FIREBASE_SERVICE_ACCOUNT_JSON=
# Option B: split service account fields
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# Auth rate limits (optional overrides)
# RATE_LIMIT_AUTH_MAX=120
# RATE_LIMIT_REGISTER_MAX=20
